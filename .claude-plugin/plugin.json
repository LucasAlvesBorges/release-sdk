{
  "name": "release",
  "description": "Full-stack acceleration kit (Django + React TSX) — context-aware routing, adversarial code review, 9-category security audit, TDD-first execution, RC1-RC7 + Q1-Q7 author checklists, N+1 detection, race-condition guards, XSS/auth-token security.",
  "version": "0.9.1",
  "author": {
    "name": "Lucas Alves Borges",
    "email": "cco@startecservicos.com.br"
  },
  "homepage": "https://github.com/LucasAlvesBorges/release-sdk",
  "repository": "https://github.com/LucasAlvesBorges/release-sdk",
  "license": "MIT",
  "keywords": [
    "django",
    "drf",
    "react",
    "tsx",
    "typescript",
    "fullstack",
    "tdd",
    "security",
    "performance",
    "multi-tenancy",
    "zustand",
    "tanstack-query",
    "vitest",
    "n-plus-one",
    "race-conditions"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/django-validate-commit.sh\"",
            "timeout": 5,
            "statusMessage": "Validating commit message..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/release-read-injection-scanner.js\"",
            "timeout": 3,
            "statusMessage": "Scanning for injection patterns..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/django-workflow-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/django-prompt-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/django-tenant-scope-check.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/react-workflow-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/react-security-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/release-context-monitor.js\"",
            "timeout": 3,
            "statusMessage": "Tracking context..."
          }
        ]
      }
    ]
  }
}
